<div class="fade-bottom"></div>
<div id="flash-overlay" style="display:none; position: absolute; left: 0; right: 0; top: 0; bottom: 0; z-index: 100"></div>
<style>html { font-size: 44px; }</style>
<div class="timestamp" style="position: absolute; bottom: .25rem; right: .25rem; font-family: 'Pixelify Sans', monospace; font-size: 8px; -webkit-font-smoothing: none; color: #777; z-index: 10; writing-mode: vertical-rl; text-orientation: mixed;">
  Noun Project icons. <%= @view_object[:attribution] if @view_object[:attribution].present? %> <%= @view_object[:timestamp] %>
</div>
<%= render Devices::StatusBarComponent.new(view_object: @view_object) %>
<div style="clear: both; line-height: .7; margin-bottom: 1rem; padding-bottom: .5rem; font-size: 3rem;">
  <div style="float: left;">
    <%= DateTime.now.strftime("%A, %b. %-d") %>
  </div>
  <div style="float: right; text-align: right;">
    <%= @view_object[:current_temperature] %>
  </div>
  <div>&nbsp;</div>
</div>
<% unless @view_object[:private_mode] %>
  <hr style="margin: 1rem 0 1rem; border: none; background-color: #ccc; color: #ccc; height: 2px;">
  <%= render Devices::TimelineComponent.new(view_object: @view_object) %>
<% end %>

<script>
(function() {
  function checkFlash() {
    var now = new Date();
    var overlay = document.getElementById('flash-overlay');
    if (!overlay) return;
    var sec = now.getSeconds();
    if (now.getMinutes() === 0 && sec >= 10 && sec < 18) {
      overlay.style.display = 'block';
      overlay.style.backgroundColor = ((sec - 10) % 4 < 2) ? 'black' : 'white';
    } else {
      overlay.style.display = 'none';
    }
  }

  checkFlash();
  setInterval(checkFlash, 1000);

  <% if @refresh && @device && @device_url %>
    var knownDeployTime = '<%= DEPLOY_TIME %>';
    var deviceUrl = '<%= @device_url %>';
    var cable = ActionCable.createConsumer();
    cable.subscriptions.create(
      { channel: 'DeviceChannel', device_id: '<%= @device.id %>' },
      {
        received: function(data) {
          if (data.deploy_time && data.deploy_time.toString() !== knownDeployTime) {
            window.location.reload();
            return;
          }
          if (data.action === 'refresh') {
            fetch(deviceUrl + '?layout=false')
              .then(function(r) { return r.text(); })
              .then(function(html) {
                document.body.innerHTML = html;
              })
              .catch(function(e) { console.error('[Timeframe] Refresh failed:', e); });
          }
        }
      }
    );
  <% end %>
})();
</script>
