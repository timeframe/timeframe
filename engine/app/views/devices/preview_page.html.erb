<div class="container-fluid py-3">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <div class="d-flex align-items-center gap-3">
      <h4 class="mb-0">Preview "<%= @device.name %>"</h4>
    </div>
    <div class="d-flex align-items-center gap-2">
      <input type="date" class="form-control form-control-sm" id="preview-date" value="<%= @preview_now.to_date.to_s %>">
      <input type="time" class="form-control form-control-sm" id="preview-time" value="<%= @preview_now.strftime("%H:%M") %>">
      <button type="button" class="btn btn-primary btn-sm" id="preview-go">Go</button>
    </div>
  </div>

  <div class="d-flex align-items-center justify-content-center" style="background: #f0f0f0; border-radius: .35rem; overflow: hidden; min-height: 400px; padding: 1rem;">
    <div id="preview-container" style="position: relative; background: white; overflow: hidden;">
      <iframe
        id="preview-iframe"
        src="<%= preview_frame_account_location_device_path(@account, @device.location, @device) %>"
        width="<%= @device.display_width %>"
        height="<%= @device.display_height %>"
        scrolling="no"
        style="border: none; position: absolute; top: 0; left: 0; width: <%= @device.display_width %>px; height: <%= @device.display_height %>px; transform-origin: top left;"
      ></iframe>
    </div>
  </div>
</div>

<script>
  (function() {
    var basePath = '<%= preview_frame_account_location_device_path(@account, @device.location, @device) %>';
    var dateInput = document.getElementById('preview-date');
    var timeInput = document.getElementById('preview-time');
    var goBtn = document.getElementById('preview-go');
    var iframe = document.getElementById('preview-iframe');
    var container = document.getElementById('preview-container');
    var deviceWidth = <%= @device.display_width %>;
    var deviceHeight = <%= @device.display_height %>;

    function updatePreview() {
      var at = dateInput.value + 'T' + timeInput.value + ':00';
      iframe.src = basePath + '?at=' + encodeURIComponent(at);
    }

    function scaleToFit() {
      var parent = container.parentElement;
      var scaleX = (parent.clientWidth - 32) / deviceWidth;
      var scaleY = (parent.clientHeight - 32) / deviceHeight;
      var scale = Math.min(scaleX, scaleY, 1);
      iframe.style.transform = 'scale(' + scale + ')';
      container.style.width = Math.floor(deviceWidth * scale) + 'px';
      container.style.height = Math.floor(deviceHeight * scale) + 'px';
    }

    goBtn.addEventListener('click', updatePreview);
    scaleToFit();
    window.addEventListener('resize', scaleToFit);
  })();
</script>
